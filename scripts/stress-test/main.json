{
  "_comment": "NodePilot Stress-Test. 16 Nodes, 25 Edges. Fächert nach log-start auf 11 parallele Branches auf: 6× runScript CPU-Burn (Primes, sqrt-Summe, SHA256, Regex-Churn, Matrix-Mult, Sort), 2× jsonQuery, 2× xmlQuery, 1× delay 55s. Alle CPU-Skripte sind Stopwatch-gegated auf 55s (CPU-unabhängige Laufzeit). Gesamt-Laufzeit: ~55-60s. runScript-Branches nutzen targetMachineId='localhost' → In-Process-Bypass, kein WinRM nötig. Layout: Main-Lane y=900, x-Step 400, y-Lane 180. Größe: 1780×1800 px.",
  "nodes": [
    {
      "id": "trigger-manual",
      "type": "activity",
      "position": { "x": 0, "y": 900 },
      "data": {
        "label": "Manual Trigger",
        "activityType": "manualTrigger",
        "config": {
          "title": "Run Stress-Test",
          "parameters": [
            {
              "name": "label",
              "type": "string",
              "required": false,
              "default": "ad-hoc"
            }
          ]
        }
      }
    },
    {
      "id": "log-start",
      "type": "activity",
      "position": { "x": 340, "y": 900 },
      "data": {
        "label": "Log: stress start",
        "activityType": "log",
        "config": {
          "level": "info",
          "message": "Stress-Test gestartet (label={{trigger-manual.param.label}}) — 11 parallele Branches, je ~55s"
        }
      }
    },
    {
      "id": "burn-primes",
      "type": "activity",
      "position": { "x": 740, "y": 0 },
      "data": {
        "label": "runScript: prime sieve (55s)",
        "activityType": "runScript",
        "targetMachineId": "localhost",
        "outputVariable": "burnPrimes",
        "config": {
          "engine": "auto",
          "timeoutSeconds": 120,
          "script": "$sw = [Diagnostics.Stopwatch]::StartNew()\n$passes = 0\n$totalPrimes = 0\nwhile ($sw.Elapsed.TotalSeconds -lt 55) {\n  $N = 2000000\n  $isComp = New-Object 'bool[]' ($N + 1)\n  for ($i = 2; $i -le [int][math]::Sqrt($N); $i++) {\n    if (-not $isComp[$i]) {\n      for ($j = $i * $i; $j -le $N; $j += $i) { $isComp[$j] = $true }\n    }\n  }\n  $primeCount = 0\n  for ($i = 2; $i -le $N; $i++) { if (-not $isComp[$i]) { $primeCount++ } }\n  $totalPrimes += $primeCount\n  $passes++\n}\n$branch = 'primes'\n$elapsed = [math]::Round($sw.Elapsed.TotalSeconds, 2)\nWrite-Host \"primes passes=$passes totalPrimes=$totalPrimes elapsed=${elapsed}s\""
        }
      }
    },
    {
      "id": "burn-sqrt",
      "type": "activity",
      "position": { "x": 740, "y": 180 },
      "data": {
        "label": "runScript: sqrt sum (55s)",
        "activityType": "runScript",
        "targetMachineId": "localhost",
        "outputVariable": "burnSqrt",
        "config": {
          "engine": "auto",
          "timeoutSeconds": 120,
          "script": "$sw = [Diagnostics.Stopwatch]::StartNew()\n$passes = 0\n$sum = 0.0\nwhile ($sw.Elapsed.TotalSeconds -lt 55) {\n  for ($i = 1; $i -le 5000000; $i++) { $sum += [math]::Sqrt($i) }\n  $passes++\n}\n$branch = 'sqrt'\n$total = [math]::Round($sum, 2)\n$elapsed = [math]::Round($sw.Elapsed.TotalSeconds, 2)\nWrite-Host \"sqrt passes=$passes sum=$total elapsed=${elapsed}s\""
        }
      }
    },
    {
      "id": "burn-hash",
      "type": "activity",
      "position": { "x": 740, "y": 360 },
      "data": {
        "label": "runScript: SHA256 chain (55s)",
        "activityType": "runScript",
        "targetMachineId": "localhost",
        "outputVariable": "burnHash",
        "config": {
          "engine": "auto",
          "timeoutSeconds": 120,
          "script": "$sw = [Diagnostics.Stopwatch]::StartNew()\n$sha = [System.Security.Cryptography.SHA256]::Create()\n$rounds = 0\n$prev = [System.Text.Encoding]::UTF8.GetBytes('nodepilot-seed')\nwhile ($sw.Elapsed.TotalSeconds -lt 55) {\n  for ($i = 0; $i -lt 50000; $i++) { $prev = $sha.ComputeHash($prev) }\n  $rounds += 50000\n}\n$sha.Dispose()\n$branch = 'hash'\n$finalHex = ($prev | ForEach-Object { $_.ToString('x2') }) -join ''\n$elapsed = [math]::Round($sw.Elapsed.TotalSeconds, 2)\nWrite-Host \"hash rounds=$rounds elapsed=${elapsed}s final=$finalHex\""
        }
      }
    },
    {
      "id": "burn-regex",
      "type": "activity",
      "position": { "x": 740, "y": 540 },
      "data": {
        "label": "runScript: regex churn (55s)",
        "activityType": "runScript",
        "targetMachineId": "localhost",
        "outputVariable": "burnRegex",
        "config": {
          "engine": "auto",
          "timeoutSeconds": 120,
          "script": "$sw = [Diagnostics.Stopwatch]::StartNew()\n$hits = 0\n$total = 0\n$pattern = '(?i)error\\s+code\\s+(\\d{3,5})'\n$rng = [System.Random]::new(42)\nwhile ($sw.Elapsed.TotalSeconds -lt 55) {\n  for ($i = 0; $i -lt 25000; $i++) {\n    $line = \"log line $total level=\" + @('info','warn','error')[$rng.Next(0,3)] + \" error code \" + $rng.Next(100,99999) + \" payload=\" + ([guid]::NewGuid())\n    if ($line -match $pattern) { $hits++ }\n    $total++\n  }\n}\n$branch = 'regex'\n$elapsed = [math]::Round($sw.Elapsed.TotalSeconds, 2)\nWrite-Host \"regex hits=$hits / total=$total elapsed=${elapsed}s\""
        }
      }
    },
    {
      "id": "burn-matrix",
      "type": "activity",
      "position": { "x": 740, "y": 720 },
      "data": {
        "label": "runScript: matrix mult (55s)",
        "activityType": "runScript",
        "targetMachineId": "localhost",
        "outputVariable": "burnMatrix",
        "config": {
          "engine": "auto",
          "timeoutSeconds": 120,
          "script": "$sw = [Diagnostics.Stopwatch]::StartNew()\n$passes = 0\n$trace = 0.0\n$rng = [System.Random]::new(1)\n$N = 200\nwhile ($sw.Elapsed.TotalSeconds -lt 55) {\n  $A = New-Object 'double[,]' $N, $N\n  $B = New-Object 'double[,]' $N, $N\n  $C = New-Object 'double[,]' $N, $N\n  for ($i = 0; $i -lt $N; $i++) { for ($j = 0; $j -lt $N; $j++) { $A[$i,$j] = $rng.NextDouble(); $B[$i,$j] = $rng.NextDouble() } }\n  for ($i = 0; $i -lt $N; $i++) {\n    for ($j = 0; $j -lt $N; $j++) {\n      $s = 0.0\n      for ($k = 0; $k -lt $N; $k++) { $s += $A[$i,$k] * $B[$k,$j] }\n      $C[$i,$j] = $s\n    }\n  }\n  for ($i = 0; $i -lt $N; $i++) { $trace += $C[$i,$i] }\n  $passes++\n}\n$branch = 'matrix'\n$traceRounded = [math]::Round($trace, 4)\n$elapsed = [math]::Round($sw.Elapsed.TotalSeconds, 2)\nWrite-Host \"matrix passes=$passes trace=$traceRounded elapsed=${elapsed}s\""
        }
      }
    },
    {
      "id": "burn-sort",
      "type": "activity",
      "position": { "x": 740, "y": 900 },
      "data": {
        "label": "runScript: sort churn (55s)",
        "activityType": "runScript",
        "targetMachineId": "localhost",
        "outputVariable": "burnSort",
        "config": {
          "engine": "auto",
          "timeoutSeconds": 120,
          "script": "$sw = [Diagnostics.Stopwatch]::StartNew()\n$N = 1000000\n$rng = [System.Random]::new(7)\n$passes = 0\n$lastMid = 0\nwhile ($sw.Elapsed.TotalSeconds -lt 55) {\n  $arr = New-Object 'int[]' $N\n  for ($i = 0; $i -lt $N; $i++) { $arr[$i] = $rng.Next() }\n  [Array]::Sort($arr)\n  $lastMid = $arr[[int]($N/2)]\n  $passes++\n}\n$branch = 'sort'\n$elapsed = [math]::Round($sw.Elapsed.TotalSeconds, 2)\nWrite-Host \"sort passes=$passes mid=$lastMid elapsed=${elapsed}s\""
        }
      }
    },
    {
