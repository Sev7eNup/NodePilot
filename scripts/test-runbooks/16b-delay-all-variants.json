{
  "schema": "nodepilot-workflow-export/v1",
  "exportVersion": 1,
  "exportedAt": "2026-05-18T00:00:00Z",
  "workflows": [
    {
      "name": "[TestSuite] delay - All Variants Live",
      "description": "Live end-to-end Test der delay-Activity. Phasen: A) Simple 1s — kuerzester Delay als Smoke-Test. B) Simple 5s — mittlerer Delay. C) Chained 3x1s — drei sequentielle 1s-Delays in Folge (Gesamt ~3s, validiert dass aufeinanderfolgende Delays NICHT parallel ausgefuehrt werden). D) Delay-between-Scripts — rs_before captured Pre-Timestamp -> delay 2s -> rs_after captured Post-Timestamp und rechnet die Differenz (TotalSeconds) aus param.elapsed. E) Delay mit Retry-Block — bei Erfolg keine Wiederholung, validiert dass Retry-Policy auf trivial-erfolgreiche Activities den Step nicht verlaengert. Pro Phase ein log-Step der seconds-Config + success-Flag aggregiert. Total ~13-14 Sekunden Laufzeit.",
      "definition": {
        "nodes": [
          { "id": "trig", "type": "activity", "position": { "x": 0, "y": 400 }, "data": { "label": "Manual: start test suite", "activityType": "manualTrigger", "config": { "parameters": [] } } },

          { "id": "init", "type": "activity", "position": { "x": 200, "y": 400 }, "data": { "label": "init: log start", "activityType": "log", "outputVariable": "init", "config": { "level": "info", "message": "[TestSuite/delay] Starting all-variants run — expect ~13s total wall time" } } },

          { "id": "d_1s", "type": "activity", "position": { "x": 500, "y": 200 }, "data": { "label": "delay: 1s simple", "activityType": "delay", "outputVariable": "d_1s", "config": { "seconds": 1 } } },
          { "id": "d_5s", "type": "activity", "position": { "x": 500, "y": 400 }, "data": { "label": "delay: 5s simple", "activityType": "delay", "outputVariable": "d_5s", "config": { "seconds": 5 } } },

          { "id": "log_simple", "type": "activity", "position": { "x": 800, "y": 200 }, "data": { "label": "log: PHASE A+B simple", "activityType": "log", "config": { "level": "info", "message": "[TestSuite/delay] PHASE A+B — simple delays: 1s={{d_1s.success}} 5s={{d_5s.success}}" } } },

          { "id": "d_chain_a", "type": "activity", "position": { "x": 500, "y": 600 }, "data": { "label": "delay: chain A 1s", "activityType": "delay", "outputVariable": "d_chain_a", "config": { "seconds": 1 } } },
          { "id": "d_chain_b", "type": "activity", "position": { "x": 800, "y": 600 }, "data": { "label": "delay: chain B 1s", "activityType": "delay", "outputVariable": "d_chain_b", "config": { "seconds": 1 } } },
          { "id": "d_chain_c", "type": "activity", "position": { "x": 1100, "y": 600 }, "data": { "label": "delay: chain C 1s", "activityType": "delay", "outputVariable": "d_chain_c", "config": { "seconds": 1 } } },

          { "id": "log_chain", "type": "activity", "position": { "x": 1400, "y": 600 }, "data": { "label": "log: PHASE C chain", "activityType": "log", "config": { "level": "info", "message": "[TestSuite/delay] PHASE C — chained 3x1s: a={{d_chain_a.success}} b={{d_chain_b.success}} c={{d_chain_c.success}}" } } },

          { "id": "rs_before", "type": "activity", "position": { "x": 500, "y": 800 }, "data": { "label": "runScript: capture preTs", "activityType": "runScript", "targetMachineId": "localhost", "outputVariable": "rs_before", "config": { "engine": "auto", "timeoutSeconds": 10, "script": "$preTs = [DateTime]::UtcNow.ToString('o')\nWrite-Output \"pre=$preTs\"" } } },
          { "id": "d_mid", "type": "activity", "position": { "x": 800, "y": 800 }, "data": { "label": "delay: 2s between scripts", "activityType": "delay", "outputVariable": "d_mid", "config": { "seconds": 2 } } },
          { "id": "rs_after", "type": "activity", "position": { "x": 1100, "y": 800 }, "data": { "label": "runScript: compute elapsed", "activityType": "runScript", "targetMachineId": "localhost", "outputVariable": "rs_after", "config": { "engine": "auto", "timeoutSeconds": 10, "script": "$preTs = {{rs_before.param.preTs}}\n$postTs = [DateTime]::UtcNow.ToString('o')\n$pre = [DateTime]::Parse($preTs)\n$post = [DateTime]::Parse($postTs)\n$elapsed = ($post - $pre).TotalSeconds.ToString('F2')\nWrite-Output \"elapsed-seconds=$elapsed\"" } } },

          { "id": "log_elapsed", "type": "activity", "position": { "x": 1400, "y": 800 }, "data": { "label": "log: PHASE D elapsed", "activityType": "log", "config": { "level": "info", "message": "[TestSuite/delay] PHASE D — elapsed between rs_before and rs_after: {{rs_after.param.elapsed}}s (expected ~2.0-2.5s)" } } },

          { "id": "d_retry", "type": "activity", "position": { "x": 500, "y": 1000 }, "data": { "label": "delay: 1s with retry block", "activityType": "delay", "outputVariable": "d_retry", "config": { "seconds": 1, "retry": { "maxAttempts": 3, "backoff": "fixed", "initialDelayMs": 500, "maxDelayMs": 2000 } } } },

          { "id": "log_retry", "type": "activity", "position": { "x": 800, "y": 1000 }, "data": { "label": "log: PHASE E retry", "activityType": "log", "config": { "level": "info", "message": "[TestSuite/delay] PHASE E — delay with retry policy: success={{d_retry.success}} (no retries expected on simple delay)" } } },

          { "id": "junc", "type": "activity", "position": { "x": 1700, "y": 600 }, "data": { "label": "junction: waitAll lanes", "activityType": "junction", "outputVariable": "junc", "config": { "mode": "waitAll" } } },

          { "id": "log_summary", "type": "activity", "position": { "x": 2000, "y": 600 }, "data": { "label": "log: SUMMARY", "activityType": "log", "config": { "level": "info", "message": "[TestSuite/delay] SUMMARY — simple: 1s={{d_1s.success}} 5s={{d_5s.success}}\nchain: a={{d_chain_a.success}} b={{d_chain_b.success}} c={{d_chain_c.success}}\nbetween-scripts: rs_before={{rs_before.success}} d_mid={{d_mid.success}} rs_after={{rs_after.success}} elapsed={{rs_after.param.elapsed}}s\nretry: d_retry={{d_retry.success}}" } } },

          { "id": "ret", "type": "activity", "position": { "x": 2300, "y": 600 }, "data": { "label": "returnData", "activityType": "returnData", "config": { "data": {
            "simple_1s": "{{d_1s.success}}",
            "simple_5s": "{{d_5s.success}}",
            "chain_a": "{{d_chain_a.success}}",
            "chain_b": "{{d_chain_b.success}}",
            "chain_c": "{{d_chain_c.success}}",
            "between_pre": "{{rs_before.success}}",
            "between_mid": "{{d_mid.success}}",
            "between_after": "{{rs_after.success}}",
            "between_elapsed_seconds": "{{rs_after.param.elapsed}}",
            "retry_success": "{{d_retry.success}}"
          } } } }
        ],
        "edges": [
          { "id": "e1", "source": "trig", "target": "init", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e2", "source": "init", "target": "d_1s", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e3", "source": "init", "target": "d_5s", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e4", "source": "d_1s", "target": "log_simple", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e5", "source": "d_5s", "target": "log_simple", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e6", "source": "init", "target": "d_chain_a", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e7", "source": "d_chain_a", "target": "d_chain_b", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e8", "source": "d_chain_b", "target": "d_chain_c", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e9", "source": "d_chain_c", "target": "log_chain", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e10", "source": "init", "target": "rs_before", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e11", "source": "rs_before", "target": "d_mid", "type": "labeled", "data": { "label": "On Success", "condition": "rs_before.success" } },
          { "id": "e12", "source": "d_mid", "target": "rs_after", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e13", "source": "rs_after", "target": "log_elapsed", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e14", "source": "init", "target": "d_retry", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e15", "source": "d_retry", "target": "log_retry", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e16", "source": "log_simple", "target": "junc", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e17", "source": "log_chain", "target": "junc", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e18", "source": "log_elapsed", "target": "junc", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e19", "source": "log_retry", "target": "junc", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e20", "source": "junc", "target": "log_summary", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e21", "source": "log_summary", "target": "ret", "type": "labeled", "data": { "label": "Always" } }
        ]
      }
    }
  ]
}
