          { "id": "st_reg_daily", "type": "activity", "position": { "x": 640, "y": 400 }, "data": { "label": "schedTask: register daily (DISABLED)", "activityType": "scheduledTask", "targetMachineId": "localhost", "disabled": true, "config": { "action": "register", "taskName": "NP-Test-Daily", "program": "C:\\Windows\\System32\\notepad.exe", "triggerType": "daily", "startTime": "03:00", "daysInterval": 1, "runAsUser": "SYSTEM" } } },
