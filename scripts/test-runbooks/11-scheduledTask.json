          { "id": "st_reg_logon", "type": "activity", "position": { "x": 640, "y": 800 }, "data": { "label": "schedTask: register atLogon (DISABLED)", "activityType": "scheduledTask", "targetMachineId": "localhost", "disabled": true, "config": { "action": "register", "taskName": "NP-Test-Logon", "program": "C:\\Windows\\System32\\notepad.exe", "triggerType": "atLogon", "runAsUser": "SYSTEM" } } },
