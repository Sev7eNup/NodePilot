          { "id": "trig", "type": "activity", "position": { "x": 0, "y": 600 }, "data": { "label": "Manual: start", "activityType": "manualTrigger", "config": { "parameters": [] } } },
          { "id": "r_createkey", "type": "activity", "position": { "x": 320, "y": 600 }, "data": { "label": "reg: createKey", "activityType": "registryOperation", "targetMachineId": "localhost", "outputVariable": "r_create", "config": { "operation": "createKey", "keyPath": "HKCU:\\Software\\NodePilot-TestSuite" } } },
