          { "id": "r_read_single", "type": "activity", "position": { "x": 1280, "y": 200 }, "data": { "label": "reg: read single", "activityType": "registryOperation", "targetMachineId": "localhost", "outputVariable": "r_read_single", "config": { "operation": "read", "keyPath": "HKCU:\\SOFTWARE\\NP-TestSuite-Reg", "valueName": "StrVal" } } },
