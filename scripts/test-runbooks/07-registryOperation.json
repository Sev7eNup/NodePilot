          { "id": "r_exists_v", "type": "activity", "position": { "x": 1280, "y": 800 }, "data": { "label": "reg: exists value", "activityType": "registryOperation", "targetMachineId": "localhost", "outputVariable": "r_exists_v", "config": { "operation": "exists", "keyPath": "HKCU:\\SOFTWARE\\NP-TestSuite-Reg", "valueName": "StrVal" } } },
          { "id": "r_list_v", "type": "activity", "position": { "x": 1280, "y": 1000 }, "data": { "label": "reg: listValues", "activityType": "registryOperation", "targetMachineId": "localhost", "outputVariable": "r_list_v", "config": { "operation": "listValues", "keyPath": "HKCU:\\SOFTWARE\\NP-TestSuite-Reg" } } },
