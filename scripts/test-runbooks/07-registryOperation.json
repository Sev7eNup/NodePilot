          { "id": "r_w_bin", "type": "activity", "position": { "x": 640, "y": 1000 }, "data": { "label": "reg: write Binary", "activityType": "registryOperation", "targetMachineId": "localhost", "outputVariable": "r_w_bin", "config": { "operation": "write", "keyPath": "HKCU:\\SOFTWARE\\NP-TestSuite-Reg", "valueName": "BinVal", "value": "DEADBEEF", "valueType": "Binary" } } },
