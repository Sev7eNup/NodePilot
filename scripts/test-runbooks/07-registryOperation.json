  "workflows": [
    {
      "name": "[TestSuite] registryOperation - All Operations & Types",
      "description": "Testet alle registryOperation-Operationen: read (single + all), write mit allen valueTypes (String/ExpandString/Binary/DWord/MultiString/QWord), createKey, exists (key + value), listSubKeys, listValues, deleteValue, deleteKey. Sandbox unter HKCU:\\SOFTWARE\\NP-TestSuite-Reg.",
      "definition": {
        "nodes": [
          { "id": "trig", "type": "activity", "position": { "x": 0, "y": 800 }, "data": { "label": "Schedule: every 5 min", "activityType": "scheduleTrigger", "config": { "cronExpression": "0 0/5 * * * ? *" } } },
          { "id": "r_create", "type": "activity", "position": { "x": 320, "y": 800 }, "data": { "label": "reg: createKey", "activityType": "registryOperation", "targetMachineId": "localhost", "outputVariable": "r_create", "config": { "operation": "createKey", "keyPath": "HKCU:\\SOFTWARE\\NP-TestSuite-Reg" } } },
