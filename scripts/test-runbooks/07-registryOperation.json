          { "id": "junc_r", "type": "activity", "position": { "x": 1600, "y": 700 }, "data": { "label": "junction: waitAll reads", "activityType": "junction", "config": { "mode": "waitAll" } } },
          { "id": "r_del_v", "type": "activity", "position": { "x": 1920, "y": 700 }, "data": { "label": "reg: deleteValue", "activityType": "registryOperation", "targetMachineId": "localhost", "outputVariable": "r_del_v", "config": { "operation": "deleteValue", "keyPath": "HKCU:\\SOFTWARE\\NP-TestSuite-Reg", "valueName": "StrVal" } } },
          { "id": "r_del_k", "type": "activity", "position": { "x": 2240, "y": 700 }, "data": { "label": "reg: deleteKey", "activityType": "registryOperation", "targetMachineId": "localhost", "outputVariable": "r_del_k", "config": { "operation": "deleteKey", "keyPath": "HKCU:\\SOFTWARE\\NP-TestSuite-Reg" } } },
          { "id": "ret", "type": "activity", "position": { "x": 2560, "y": 700 }, "data": { "label": "returnData", "activityType": "returnData", "config": { "data": { "single": "{{r_read_single.param.value}}", "type": "{{r_read_single.param.type}}", "valuesCount": "{{r_read_all.param.count}}", "keyExists": "{{r_exists_k.param.exists}}", "valExists": "{{r_exists_v.param.exists}}", "subKeyCount": "{{r_list_sub.param.count}}" } } } }
        ],
