{
  "schema": "nodepilot-workflow-export/v1",
  "exportVersion": 1,
  "exportedAt": "2026-05-18T00:00:00Z",
  "workflows": [
    {
      "name": "[TestSuite] log - All Variants Live",
      "description": "Live end-to-end Test der log-Activity. Phasen: A) Level-Coverage info/warning/error — alle drei landen im Serilog Console+File-Sink, im StepDetail-Log und in der SupportEvents-DB-Projection (level wird als Property propagiert). B) Variable-Interpolation aus Upstream — output, param.*, success-Flag. C) Multi-line Message — \\n im JSON, Newlines werden im Log-Output sichtbar gerendert. D) Empty/Minimal Message — ein einzelnes 'ok' als Edge-Case, log akzeptiert leere/kurze Messages. E) Unresolved-Template-Diag — referenziert einen NICHT-existierenden Step ({{missing_step.output}}), Engine soll mit granularer Diagnostik failen (StepRunner T-7.1: 'Step existiert nicht: missing_step'). Dieser Phase-E-Step ist BEWUSST so gebaut, dass er failt — die failure-Edge wird zu log_e_fail (Always); Phase E NICHT auf die summary-Lane mappen.",
      "definition": {
        "nodes": [
          { "id": "trig", "type": "activity", "position": { "x": 0, "y": 500 }, "data": { "label": "Manual: start test suite", "activityType": "manualTrigger", "config": { "parameters": [] } } },

          { "id": "init", "type": "activity", "position": { "x": 200, "y": 500 }, "data": { "label": "init: vars + flags", "activityType": "runScript", "targetMachineId": "localhost", "outputVariable": "init", "config": { "engine": "auto", "timeoutSeconds": 10, "script": "$msg = 'hello-from-init'\n$num = '42'\n$flag = 'true'\nWrite-Output 'init-output-line'" } } },

          { "id": "log_info", "type": "activity", "position": { "x": 500, "y": 200 }, "data": { "label": "log: info level", "activityType": "log", "outputVariable": "log_info", "config": { "level": "info", "message": "[TestSuite/log][info] plain info level — numeric={{init.param.num}}" } } },
          { "id": "log_warn", "type": "activity", "position": { "x": 500, "y": 360 }, "data": { "label": "log: warning level", "activityType": "log", "outputVariable": "log_warn", "config": { "level": "warning", "message": "[TestSuite/log][warn] warning level — msg={{init.param.msg}}" } } },
          { "id": "log_err", "type": "activity", "position": { "x": 500, "y": 520 }, "data": { "label": "log: error level", "activityType": "log", "outputVariable": "log_err", "config": { "level": "error", "message": "[TestSuite/log][error] error level — flag={{init.param.flag}} output={{init.output}}" } } },

          { "id": "log_a_summary", "type": "activity", "position": { "x": 800, "y": 360 }, "data": { "label": "log: PHASE A levels", "activityType": "log", "config": { "level": "info", "message": "[TestSuite/log] PHASE A — levels: info={{log_info.success}} warn={{log_warn.success}} err={{log_err.success}}" } } },

          { "id": "log_interp", "type": "activity", "position": { "x": 500, "y": 700 }, "data": { "label": "log: variable interp 3-source", "activityType": "log", "outputVariable": "log_interp", "config": { "level": "info", "message": "[TestSuite/log][interp] output={{init.output}} | param.msg={{init.param.msg}} | param.num={{init.param.num}} | success={{init.success}}" } } },

          { "id": "log_multi", "type": "activity", "position": { "x": 500, "y": 860 }, "data": { "label": "log: multi-line", "activityType": "log", "outputVariable": "log_multi", "config": { "level": "info", "message": "[TestSuite/log][multi] Line 1: header\nLine 2: msg={{init.param.msg}}\nLine 3: num={{init.param.num}}\nLine 4: flag={{init.param.flag}}\nLine 5: footer" } } },

          { "id": "log_min", "type": "activity", "position": { "x": 500, "y": 1020 }, "data": { "label": "log: minimal 'ok'", "activityType": "log", "outputVariable": "log_min", "config": { "level": "info", "message": "ok" } } },

          { "id": "log_bcd_summary", "type": "activity", "position": { "x": 800, "y": 860 }, "data": { "label": "log: PHASE B+C+D", "activityType": "log", "config": { "level": "info", "message": "[TestSuite/log] PHASE B+C+D — interp={{log_interp.success}} multi={{log_multi.success}} minimal={{log_min.success}}" } } },

          { "id": "log_e_fail", "type": "activity", "position": { "x": 500, "y": 1200 }, "data": { "label": "log: unresolved-template (expect FAIL)", "activityType": "log", "outputVariable": "log_e_fail", "config": { "level": "warning", "message": "[TestSuite/log][unresolved] referencing missing step: {{missing_step.output}} and {{nonexistent.param.foo}} — expect granular diagnostic" } } },

          { "id": "log_e_summary", "type": "activity", "position": { "x": 800, "y": 1200 }, "data": { "label": "log: PHASE E result", "activityType": "log", "config": { "level": "info", "message": "[TestSuite/log] PHASE E — unresolved-template step success={{log_e_fail.success}} (expected false). Error text intentionally NOT interpolated to avoid re-resolving its embedded placeholders." } } },

          { "id": "junc", "type": "activity", "position": { "x": 1100, "y": 600 }, "data": { "label": "junction: waitAll lanes", "activityType": "junction", "outputVariable": "junc", "config": { "mode": "waitAll" } } },

          { "id": "log_summary", "type": "activity", "position": { "x": 1400, "y": 600 }, "data": { "label": "log: SUMMARY", "activityType": "log", "config": { "level": "info", "message": "[TestSuite/log] SUMMARY — levels: info={{log_info.success}} warn={{log_warn.success}} err={{log_err.success}}\ninterp={{log_interp.success}} multi={{log_multi.success}} minimal={{log_min.success}}\nunresolved={{log_e_fail.success}} (expected false)" } } },

          { "id": "ret", "type": "activity", "position": { "x": 1700, "y": 600 }, "data": { "label": "returnData", "activityType": "returnData", "config": { "data": {
            "level_info": "{{log_info.success}}",
            "level_warning": "{{log_warn.success}}",
            "level_error": "{{log_err.success}}",
            "interp_success": "{{log_interp.success}}",
            "multi_success": "{{log_multi.success}}",
            "minimal_success": "{{log_min.success}}",
            "unresolved_success": "{{log_e_fail.success}}",
            "unresolved_diag_present": "true"
          } } } }
        ],
        "edges": [
          { "id": "e1", "source": "trig", "target": "init", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e2", "source": "init", "target": "log_info", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e3", "source": "init", "target": "log_warn", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e4", "source": "init", "target": "log_err", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e5", "source": "log_info", "target": "log_a_summary", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e6", "source": "log_warn", "target": "log_a_summary", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e7", "source": "log_err", "target": "log_a_summary", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e8", "source": "init", "target": "log_interp", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e9", "source": "init", "target": "log_multi", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e10", "source": "init", "target": "log_min", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e11", "source": "log_interp", "target": "log_bcd_summary", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e12", "source": "log_multi", "target": "log_bcd_summary", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e13", "source": "log_min", "target": "log_bcd_summary", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e14", "source": "init", "target": "log_e_fail", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e15", "source": "log_e_fail", "target": "log_e_summary", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e16", "source": "log_a_summary", "target": "junc", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e17", "source": "log_bcd_summary", "target": "junc", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e18", "source": "log_e_summary", "target": "junc", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e19", "source": "junc", "target": "log_summary", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e20", "source": "log_summary", "target": "ret", "type": "labeled", "data": { "label": "Always" } }
        ]
      }
    }
  ]
}
