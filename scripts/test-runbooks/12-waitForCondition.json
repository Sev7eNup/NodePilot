{
  "schema": "nodepilot-workflow-export/v1",
  "exportVersion": 1,
  "exportedAt": "2026-05-10T00:00:00Z",
  "workflows": [
    {
      "name": "[TestSuite] waitForCondition - Polling Patterns",
      "description": "Testet waitForCondition mit Always-True (immediate), Service-Status-Poll (Spooler Running) und Datei-Existenz-Poll (mit Vorbereitung). Timeout-Pfad in xUnit unit test abgedeckt.",
      "definition": {
        "nodes": [
          { "id": "trig", "type": "activity", "position": { "x": 0, "y": 400 }, "data": { "label": "Schedule: every 5 min", "activityType": "scheduleTrigger", "config": { "cronExpression": "0 0/5 * * * ? *" } } },
          { "id": "wfc_true", "type": "activity", "position": { "x": 320, "y": 200 }, "data": { "label": "wait: $true (immediate)", "activityType": "waitForCondition", "targetMachineId": "localhost", "outputVariable": "wfc_true", "config": { "script": "$true", "intervalSeconds": 1, "timeoutSeconds": 10 } } },
          { "id": "wfc_svc", "type": "activity", "position": { "x": 320, "y": 400 }, "data": { "label": "wait: Spooler Running", "activityType": "waitForCondition", "targetMachineId": "localhost", "outputVariable": "wfc_svc", "config": { "conditionType": "serviceRunning", "serviceName": "Spooler", "intervalSeconds": 2, "timeoutSeconds": 30 } } },
          { "id": "prep_file", "type": "activity", "position": { "x": 320, "y": 600 }, "data": { "label": "runScript: create flag file", "activityType": "runScript", "targetMachineId": "localhost", "outputVariable": "prep", "config": { "engine": "auto", "timeoutSeconds": 10, "script": "$dir = 'C:\\Temp\\NP-TestSuite\\wait-' + [Guid]::NewGuid().ToString('N')\nNew-Item -Path $dir -ItemType Directory -Force | Out-Null\n$flagPath = Join-Path $dir 'flag.txt'\nNew-Item -Path $flagPath -ItemType File -Force | Out-Null\nWrite-Output $flagPath" } } },
          { "id": "wfc_file", "type": "activity", "position": { "x": 640, "y": 600 }, "data": { "label": "wait: file exists (dynamic path via pathExists mode)", "activityType": "waitForCondition", "targetMachineId": "localhost", "outputVariable": "wfc_file", "config": { "conditionType": "pathExists", "path": "{{prep.param.flagPath}}", "intervalSeconds": 1, "timeoutSeconds": 15 } } },
          { "id": "cleanup", "type": "activity", "position": { "x": 960, "y": 600 }, "data": { "label": "runScript: cleanup", "activityType": "runScript", "targetMachineId": "localhost", "outputVariable": "cleanup", "config": { "engine": "auto", "timeoutSeconds": 10, "script": "$flag = {{prep.param.flagPath}}\n$parent = Split-Path $flag\nif (Test-Path $parent) { Remove-Item -LiteralPath $parent -Recurse -Force }\nWrite-Output 'cleanup-ok'" } } },
          { "id": "junc", "type": "activity", "position": { "x": 1280, "y": 400 }, "data": { "label": "junction: waitAll", "activityType": "junction", "config": { "mode": "waitAll" } } },
          { "id": "ret", "type": "activity", "position": { "x": 1600, "y": 400 }, "data": { "label": "returnData", "activityType": "returnData", "config": { "data": { "trueAttempts": "{{wfc_true.param.attempts}}", "svcAttempts": "{{wfc_svc.param.attempts}}", "fileAttempts": "{{wfc_file.param.attempts}}" } } } }
        ],
        "edges": [
          { "id": "e1", "source": "trig", "target": "wfc_true", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e2", "source": "trig", "target": "wfc_svc", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e3", "source": "trig", "target": "prep_file", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e4", "source": "prep_file", "target": "wfc_file", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e5", "source": "wfc_file", "target": "cleanup", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e6", "source": "wfc_true", "target": "junc", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e7", "source": "wfc_svc", "target": "junc", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e8", "source": "cleanup", "target": "junc", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e9", "source": "junc", "target": "ret", "type": "labeled", "data": { "label": "Always" } }
        ]
      }
    }
  ]
}
