{
  "schema": "nodepilot-workflow-export/v1",
  "exportVersion": 1,
  "exportedAt": "2026-05-18T00:00:00Z",
  "workflows": [
    {
      "name": "[TestSuite] fileOperation - All Variants Live",
      "description": "Live end-to-end Test der fileOperation-Activity ueber alle 6 Operationen (create/exists/rename/copy/move/delete). Sandbox: C:\\temp\\nodepilot-fileop-test. Setup runScript legt Sandbox + Seed-File an, dann pro Operation ein Step mit outputVariable, danach Phase-Log mit aggregierten Erfolgswerten. Teardown runScript loescht Sandbox. Phasen: 0) Setup (mkdir + seed). A) create empty file + exists(true). B) rename. C) copy. D) move. E) delete + exists(false). F) Cleanup teardown. G) Summary log + returnData. Output landet im NodePilot-Serilog + SupportEvents-DB-Projection.",
      "definition": {
        "nodes": [
          { "id": "trig", "type": "activity", "position": { "x": 0, "y": 400 }, "data": { "label": "Manual: start test suite", "activityType": "manualTrigger", "config": { "parameters": [] } } },

          { "id": "setup", "type": "activity", "position": { "x": 160, "y": 400 }, "data": { "label": "runScript: setup sandbox + seed", "activityType": "runScript", "targetMachineId": "localhost", "outputVariable": "setup", "config": { "engine": "auto", "timeoutSeconds": 10, "script": "$ErrorActionPreference = 'Stop'\n$sandbox = 'C:\\temp\\nodepilot-fileop-test'\nif (Test-Path -LiteralPath $sandbox) { Remove-Item -LiteralPath $sandbox -Recurse -Force }\nNew-Item -Path $sandbox -ItemType Directory -Force | Out-Null\n$seedPath = Join-Path $sandbox 'seed.txt'\nSet-Content -LiteralPath $seedPath -Value 'NodePilot-fileop-test-seed' -Encoding UTF8\nWrite-Output \"sandbox-ready: $sandbox\"" } } },

          { "id": "log_setup", "type": "activity", "position": { "x": 160, "y": 240 }, "data": { "label": "log: setup phase", "activityType": "log", "config": { "level": "info", "message": "[TestSuite/fileOperation] PHASE 0 - Setup: success={{setup.success}} output={{setup.output}}" } } },

          { "id": "f_create", "type": "activity", "position": { "x": 480, "y": 400 }, "data": { "label": "fileOp: create alpha.txt", "activityType": "fileOperation", "targetMachineId": "localhost", "outputVariable": "f_create", "config": { "operation": "create", "path": "C:\\temp\\nodepilot-fileop-test\\alpha.txt" } } },
          { "id": "f_exists_t", "type": "activity", "position": { "x": 800, "y": 400 }, "data": { "label": "fileOp: exists alpha (true)", "activityType": "fileOperation", "targetMachineId": "localhost", "outputVariable": "f_exists_t", "config": { "operation": "exists", "path": "C:\\temp\\nodepilot-fileop-test\\alpha.txt" } } },

          { "id": "log_create", "type": "activity", "position": { "x": 1120, "y": 400 }, "data": { "label": "log: create+exists phase", "activityType": "log", "config": { "level": "info", "message": "[TestSuite/fileOperation] PHASE A - create+exists: create.success={{f_create.success}} fullName={{f_create.param.fullName}} exists.success={{f_exists_t.success}} exists.value={{f_exists_t.param.exists}}" } } },

          { "id": "f_rename", "type": "activity", "position": { "x": 1440, "y": 400 }, "data": { "label": "fileOp: rename alpha->beta", "activityType": "fileOperation", "targetMachineId": "localhost", "outputVariable": "f_rename", "config": { "operation": "rename", "path": "C:\\temp\\nodepilot-fileop-test\\alpha.txt", "newName": "beta.txt" } } },

          { "id": "log_rename", "type": "activity", "position": { "x": 1760, "y": 400 }, "data": { "label": "log: rename phase", "activityType": "log", "config": { "level": "info", "message": "[TestSuite/fileOperation] PHASE B - rename: success={{f_rename.success}} newPath={{f_rename.param.newPath}} newName={{f_rename.param.newName}}" } } },

          { "id": "f_copy", "type": "activity", "position": { "x": 2080, "y": 400 }, "data": { "label": "fileOp: copy beta->gamma", "activityType": "fileOperation", "targetMachineId": "localhost", "outputVariable": "f_copy", "config": { "operation": "copy", "path": "C:\\temp\\nodepilot-fileop-test\\beta.txt", "destination": "C:\\temp\\nodepilot-fileop-test\\gamma.txt" } } },

          { "id": "log_copy", "type": "activity", "position": { "x": 2400, "y": 400 }, "data": { "label": "log: copy phase", "activityType": "log", "config": { "level": "info", "message": "[TestSuite/fileOperation] PHASE C - copy: success={{f_copy.success}} destination={{f_copy.param.destination}}" } } },

          { "id": "f_move", "type": "activity", "position": { "x": 2720, "y": 400 }, "data": { "label": "fileOp: move gamma->delta", "activityType": "fileOperation", "targetMachineId": "localhost", "outputVariable": "f_move", "config": { "operation": "move", "path": "C:\\temp\\nodepilot-fileop-test\\gamma.txt", "destination": "C:\\temp\\nodepilot-fileop-test\\delta.txt" } } },

          { "id": "log_move", "type": "activity", "position": { "x": 3040, "y": 400 }, "data": { "label": "log: move phase", "activityType": "log", "config": { "level": "info", "message": "[TestSuite/fileOperation] PHASE D - move: success={{f_move.success}} destination={{f_move.param.destination}}" } } },

          { "id": "f_delete", "type": "activity", "position": { "x": 3040, "y": 580 }, "data": { "label": "fileOp: delete delta", "activityType": "fileOperation", "targetMachineId": "localhost", "outputVariable": "f_delete", "config": { "operation": "delete", "path": "C:\\temp\\nodepilot-fileop-test\\delta.txt" } } },
          { "id": "f_exists_f", "type": "activity", "position": { "x": 2720, "y": 580 }, "data": { "label": "fileOp: exists delta (false)", "activityType": "fileOperation", "targetMachineId": "localhost", "outputVariable": "f_exists_f", "config": { "operation": "exists", "path": "C:\\temp\\nodepilot-fileop-test\\delta.txt" } } },

          { "id": "log_delete", "type": "activity", "position": { "x": 2400, "y": 580 }, "data": { "label": "log: delete+exists phase", "activityType": "log", "config": { "level": "info", "message": "[TestSuite/fileOperation] PHASE E - delete+exists: delete.success={{f_delete.success}} exists.success={{f_exists_f.success}} exists.value={{f_exists_f.param.exists}}" } } },

          { "id": "teardown", "type": "activity", "position": { "x": 2080, "y": 580 }, "data": { "label": "runScript: teardown sandbox", "activityType": "runScript", "targetMachineId": "localhost", "outputVariable": "teardown", "config": { "engine": "auto", "timeoutSeconds": 10, "script": "$ErrorActionPreference = 'Stop'\n$sandbox = 'C:\\temp\\nodepilot-fileop-test'\nif (Test-Path -LiteralPath $sandbox) { Remove-Item -LiteralPath $sandbox -Recurse -Force }\nWrite-Output 'teardown-ok'" } } },

          { "id": "log_teardown", "type": "activity", "position": { "x": 1760, "y": 580 }, "data": { "label": "log: teardown phase", "activityType": "log", "config": { "level": "info", "message": "[TestSuite/fileOperation] PHASE F - teardown: success={{teardown.success}} output={{teardown.output}}" } } },

          { "id": "log_summary", "type": "activity", "position": { "x": 1440, "y": 580 }, "data": { "label": "log: SUMMARY", "activityType": "log", "config": { "level": "info", "message": "[TestSuite/fileOperation] SUMMARY - All 6 operations covered.\ncreate={{f_create.success}} (fullName={{f_create.param.fullName}})\nexists_true={{f_exists_t.success}} (value={{f_exists_t.param.exists}})\nrename={{f_rename.success}} (newPath={{f_rename.param.newPath}})\ncopy={{f_copy.success}} (dest={{f_copy.param.destination}})\nmove={{f_move.success}} (dest={{f_move.param.destination}})\ndelete={{f_delete.success}}\nexists_false={{f_exists_f.success}} (value={{f_exists_f.param.exists}})\nteardown={{teardown.success}}" } } },

          { "id": "ret", "type": "activity", "position": { "x": 1120, "y": 580 }, "data": { "label": "returnData", "activityType": "returnData", "config": { "data": {
            "setup_success": "{{setup.success}}",
            "create_success": "{{f_create.success}}",
            "create_fullName": "{{f_create.param.fullName}}",
            "exists_true_success": "{{f_exists_t.success}}",
            "exists_true_value": "{{f_exists_t.param.exists}}",
            "rename_success": "{{f_rename.success}}",
            "rename_newPath": "{{f_rename.param.newPath}}",
            "rename_newName": "{{f_rename.param.newName}}",
            "copy_success": "{{f_copy.success}}",
            "copy_destination": "{{f_copy.param.destination}}",
            "move_success": "{{f_move.success}}",
            "move_destination": "{{f_move.param.destination}}",
            "delete_success": "{{f_delete.success}}",
            "exists_false_success": "{{f_exists_f.success}}",
            "exists_false_value": "{{f_exists_f.param.exists}}",
            "teardown_success": "{{teardown.success}}"
          } } } }
        ],
        "edges": [
          { "id": "e1", "source": "trig", "target": "setup", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e2", "source": "setup", "target": "log_setup", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e3", "source": "setup", "target": "f_create", "type": "labeled", "data": { "label": "On Success", "condition": "setup.success" } },
          { "id": "e4", "source": "f_create", "target": "f_exists_t", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e5", "source": "f_exists_t", "target": "log_create", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e6", "source": "log_create", "target": "f_rename", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e7", "source": "f_rename", "target": "log_rename", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e8", "source": "log_rename", "target": "f_copy", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e9", "source": "f_copy", "target": "log_copy", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e10", "source": "log_copy", "target": "f_move", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e11", "source": "f_move", "target": "log_move", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e12", "source": "log_move", "target": "f_delete", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e13", "source": "f_delete", "target": "f_exists_f", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e14", "source": "f_exists_f", "target": "log_delete", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e15", "source": "log_delete", "target": "teardown", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e16", "source": "teardown", "target": "log_teardown", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e17", "source": "log_teardown", "target": "log_summary", "type": "labeled", "data": { "label": "Always" } },
          { "id": "e18", "source": "log_summary", "target": "ret", "type": "labeled", "data": { "label": "Always" } }
        ]
      }
    }
  ]
}
