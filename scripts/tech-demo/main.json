      "id": "e-collect-prog",
      "source": "collect-host",
      "target": "prog-cmd",
      "type": "labeled",
      "data": {
        "label": "hostName set & cpu>=1",
        "conditionExpression": {
          "type": "group",
          "op": "AND",
          "children": [
            {
              "type": "comparison",
              "op": "isNotEmpty",
              "left": {
                "kind": "variable",
                "stepId": "collect-host",
                "field": "param",
                "paramName": "hostName"
              }
            },
            {
              "type": "comparison",
              "op": ">=",
              "left": {
                "kind": "variable",
                "stepId": "collect-host",
                "field": "param",
                "paramName": "cpuCount"
              },
              "right": {
                "kind": "literal",
                "value": "1"
              }
            }
          ]
        }
      }
    },
