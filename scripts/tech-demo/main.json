    {
      "id": "e-jall-eqneq",
      "source": "junction-all",
      "target": "log-eq-neq",
      "type": "labeled",
      "data": {
        "label": "env==prod & env!=stg",
        "conditionExpression": {
          "type": "group",
          "op": "AND",
          "children": [
            {
              "type": "comparison",
              "op": "==",
