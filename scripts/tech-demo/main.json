    {
      "id": "collect-host",
      "type": "activity",
      "position": {
        "x": 920,
        "y": 480
      },
      "data": {
        "label": "runScript: collect host info",
        "activityType": "runScript",
        "targetMachineId": "localhost",
        "outputVariable": "host",
        "config": {
          "engine": "auto",
          "timeoutSeconds": 60,
          "retry": {
            "maxAttempts": 2,
            "backoff": "exponential",
            "initialDelayMs": 500,
            "maxDelayMs": 5000
          },
          "script": "# Every variable declared here is captured as {{host.param.<name>}} for downstream use.\n$hostName    = $env:COMPUTERNAME\n$userName    = $env:USERNAME\n$now         = (Get-Date).ToString('yyyy-MM-dd HH:mm:ss')\n$osCim       = Get-CimInstance Win32_OperatingSystem -ErrorAction SilentlyContinue\n$osName      = if ($osCim) { $osCim.Caption } else { 'Microsoft Windows' }\n$osVersion   = [System.Environment]::OSVersion.Version.ToString()\n$buildNumber = ($osVersion -split '\\.')[2]\n$cpuCount    = [System.Environment]::ProcessorCount\n$drive       = Get-PSDrive C -ErrorAction SilentlyContinue\nif ($drive) {\n    $diskFreeGB  = [math]::Round($drive.Free / 1GB, 2)\n    $diskUsedGB  = [math]::Round($drive.Used / 1GB, 2)\n    $diskTotalGB = [math]::Round(($drive.Free + $drive.Used) / 1GB, 2)\n    $diskUsedPct = [math]::Round(($drive.Used / ($drive.Free + $drive.Used)) * 100, 1)\n} else {\n    $diskFreeGB = 0; $diskUsedGB = 0; $diskTotalGB = 0; $diskUsedPct = 0\n}\n$cs          = Get-CimInstance Win32_ComputerSystem -ErrorAction SilentlyContinue\n$isDomain    = if ($cs) { [bool]$cs.PartOfDomain } else { $false }\n$emptyField  = ''\n$errorLog    = ''\nWrite-Output \"Collected $cpuCount CPU(s), $diskFreeGB/$diskTotalGB GB free ($diskUsedPct% used) as $userName@$hostName (OS: $osName v$osVersion build $buildNumber, domain=$isDomain) at $now\""
        }
      }
    },
