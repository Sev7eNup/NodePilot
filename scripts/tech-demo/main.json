{
  "_comment": "NodePilot Tech-Demo - Full Showcase. 37 nodes, ~55 edges. Covers all 17 activities, all 14 edge operators + AND/OR/NOT, all 3 junction modes (waitAll, waitAny, waitNofM), retry policies, step-timeouts, node-level disabled, breakpoint, disabled edge, sub-workflow, On-Success/On-Failure error paths. LTR layout: x-step 260, y-lane 160, main lane y=480. Build: ~5200x1120 px.",
  "nodes": [
    {
      "id": "trigger-manual",
      "type": "activity",
      "position": {
        "x": 0,
        "y": 480
      },
      "data": {
        "label": "Manual Trigger (4 params)",
        "activityType": "manualTrigger",
        "config": {
          "title": "Run Tech-Demo",
          "parameters": [
            {
              "name": "environment",
              "type": "string",
              "required": true,
              "default": "staging"
            },
            {
              "name": "threshold",
              "type": "string",
              "required": false,
              "default": "80"
            },
            {
              "name": "dryRun",
              "type": "string",
              "required": false,
              "default": "false"
            },
            {
              "name": "pattern",
              "type": "string",
              "required": false,
              "default": "Windows.*"
            }
          ]
        }
      }
    },
    {
      "id": "log-start",
      "type": "activity",
      "position": {
        "x": 320,
        "y": 480
      },
      "data": {
        "label": "Log: workflow started",
        "activityType": "log",
        "config": {
          "level": "info",
          "message": "Tech-Demo started: env={{trigger-manual.param.environment}} threshold={{trigger-manual.param.threshold}} dryRun={{trigger-manual.param.dryRun}} pattern={{trigger-manual.param.pattern}}"
        }
      }
    },
