    { "id": "e-delay-logecho",    "source": "delay-init",     "target": "log-env-echo",  "type": "labeled", "data": { "label": "Always" } },
    { "id": "e-logecho-collect",  "source": "log-env-echo",   "target": "collect-host",  "type": "labeled", "data": { "label": "Always" } },

    { "id": "e-collect-file",     "source": "collect-host", "target": "file-exists",
      "type": "labeled",
      "data": {
        "label": "hostName set",
        "conditionExpression": {
          "type": "comparison",
          "op": "isNotEmpty",
          "left": { "kind": "variable", "stepId": "collect-host", "field": "param", "paramName": "hostName" }
        }
      }
    },
    { "id": "e-collect-svc",      "source": "collect-host", "target": "svc-status",  "type": "labeled", "data": { "label": "On Success", "condition": "collect-host.success" } },
    { "id": "e-collect-reg",      "source": "collect-host", "target": "reg-read",    "type": "labeled", "data": { "label": "Always" } },
    { "id": "e-collect-wmi",      "source": "collect-host", "target": "wmi-os",      "type": "labeled", "data": { "label": "On Success", "condition": "collect-host.success" } },
    { "id": "e-collect-prog",     "source": "collect-host", "target": "prog-cmd",
      "type": "labeled",
      "data": {
        "label": "hostName set & cpu>=1",
        "conditionExpression": {
          "type": "group", "op": "AND",
          "children": [
            { "type": "comparison", "op": "isNotEmpty", "left": { "kind": "variable", "stepId": "collect-host", "field": "param", "paramName": "hostName" } },
            { "type": "comparison", "op": ">=",
              "left":  { "kind": "variable", "stepId": "collect-host", "field": "param", "paramName": "cpuCount" },
              "right": { "kind": "literal", "value": "1" }
            }
          ]
        }
      }
    },
    { "id": "e-collect-list",     "source": "collect-host", "target": "file-list",   "type": "labeled", "data": { "label": "Always" } },

    { "id": "e-file-jall1",   "source": "file-exists", "target": "junction-all-1", "type": "labeled", "data": { "label": "Always" } },
