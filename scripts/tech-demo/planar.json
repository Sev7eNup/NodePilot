{
  "_comment": "NodePilot Tech-Demo - Planar Showcase. 50 nodes, 63 edges, 8380x1200 px. Strictly planar layout: every edge spans exactly one x-column (x=N -> x=N+1), no skip-edges, no same-column edges, no backward edges. Fan-outs from a single source and fan-ins to a single target are crossing-free by construction. Parallel multi-rank branches preserve their y-lane. Covers 19 activity types, all 14 edge operators + AND/OR/NOT, all 3 junction modes, retry policies, step timeouts, node-level disabled, breakpoint, disabled edge, sub-workflow (both waitForCompletion true and false), forEach, powerManagement. References the same child workflow as main.json / xl.json ('NodePilot Tech-Demo - Child'). Main lane y=480.",
  "nodes": [
    {
      "id": "trigger-manual",
      "type": "activity",
      "position": { "x": 0, "y": 480 },
      "data": {
        "label": "Manual Trigger (4 params)",
        "activityType": "manualTrigger",
        "config": {
          "title": "Run Planar Showcase",
          "parameters": [
            { "name": "environment", "type": "string", "required": true,  "default": "staging" },
            { "name": "threshold",   "type": "string", "required": false, "default": "80" },
            { "name": "dryRun",      "type": "string", "required": false, "default": "false" },
            { "name": "pattern",     "type": "string", "required": false, "default": "Windows.*" }
          ]
        }
      }
    },
