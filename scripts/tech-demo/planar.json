    { "id": "e-reg-jall1",    "source": "reg-read",    "target": "junction-all-1", "type": "labeled", "data": { "label": "Always" } },
    { "id": "e-wmi-jall1",    "source": "wmi-os",      "target": "junction-all-1", "type": "labeled", "data": { "label": "Always" } },
    { "id": "e-prog-jall1",   "source": "prog-cmd",    "target": "junction-all-1", "type": "labeled", "data": { "label": "Always" } },
    { "id": "e-list-jall1",   "source": "file-list",   "target": "junction-all-1", "type": "labeled", "data": { "label": "Always" } },

    { "id": "e-jall1-eqneq",  "source": "junction-all-1", "target": "log-eq-neq",
      "type": "labeled",
      "data": {
        "label": "env==prod & env!=stg",
        "conditionExpression": {
          "type": "group", "op": "AND",
          "children": [
            { "type": "comparison", "op": "==", "left": { "kind": "variable", "stepId": "trigger-manual", "field": "param", "paramName": "environment" }, "right": { "kind": "literal", "value": "production" } },
            { "type": "comparison", "op": "!=", "left": { "kind": "variable", "stepId": "trigger-manual", "field": "param", "paramName": "environment" }, "right": { "kind": "literal", "value": "staging" } }
          ]
        }
      }
    },
    { "id": "e-jall1-range",  "source": "junction-all-1", "target": "log-range",
      "type": "labeled",
      "data": {
        "label": "cpu in [1..128]",
        "conditionExpression": {
          "type": "group", "op": "AND",
          "children": [
            { "type": "comparison", "op": ">=", "left": { "kind": "variable", "stepId": "collect-host", "field": "param", "paramName": "cpuCount" }, "right": { "kind": "literal", "value": "1" } },
            { "type": "comparison", "op": "<=", "left": { "kind": "variable", "stepId": "collect-host", "field": "param", "paramName": "cpuCount" }, "right": { "kind": "literal", "value": "128" } }
          ]
        }
      }
    },
    { "id": "e-jall1-diskalarm", "source": "junction-all-1", "target": "log-disk-alarm",
      "type": "labeled",
      "data": {
        "label": "disk% > thr  OR  free < 1GB",
        "conditionExpression": {
          "type": "group", "op": "OR",
          "children": [
            { "type": "comparison", "op": ">", "left":  { "kind": "variable", "stepId": "collect-host", "field": "param", "paramName": "diskUsedPct" }, "right": { "kind": "variable", "stepId": "trigger-manual", "field": "param", "paramName": "threshold" } },
            { "type": "comparison", "op": "<", "left":  { "kind": "variable", "stepId": "collect-host", "field": "param", "paramName": "diskFreeGB" }, "right": { "kind": "literal", "value": "1" } }
          ]
        }
      }
    },
    { "id": "e-jall1-strings", "source": "junction-all-1", "target": "log-strings",
      "type": "labeled",
      "data": {
        "label": "contains+starts+ends+matches",
        "conditionExpression": {
          "type": "group", "op": "AND",
          "children": [
            { "type": "comparison", "op": "contains",   "left": { "kind": "variable", "stepId": "collect-host", "field": "param", "paramName": "osName" },    "right": { "kind": "literal", "value": "Windows" } },
            { "type": "comparison", "op": "startsWith", "left": { "kind": "variable", "stepId": "collect-host", "field": "param", "paramName": "osName" },    "right": { "kind": "literal", "value": "Microsoft" } },
            { "type": "comparison", "op": "endsWith",   "left": { "kind": "variable", "stepId": "collect-host", "field": "param", "paramName": "osName" },    "right": { "kind": "literal", "value": "Pro" } },
            { "type": "comparison", "op": "matches",    "left": { "kind": "variable", "stepId": "collect-host", "field": "param", "paramName": "osVersion" }, "right": { "kind": "literal", "value": "^10\\." } }
          ]
        }
      }
    },
    { "id": "e-jall1-unarypos", "source": "junction-all-1", "target": "log-unary-pos",
      "type": "labeled",
      "data": {
        "label": "output set & isDomain",
        "conditionExpression": {
          "type": "group", "op": "AND",
          "children": [
            { "type": "comparison", "op": "isNotEmpty", "left": { "kind": "variable", "stepId": "collect-host", "field": "output" } },
            { "type": "comparison", "op": "isTrue",     "left": { "kind": "variable", "stepId": "collect-host", "field": "param", "paramName": "isDomain" } }
          ]
        }
      }
    },
    { "id": "e-jall1-unaryneg", "source": "junction-all-1", "target": "log-unary-neg",
      "type": "labeled",
      "data": {
        "label": "empty & !dry",
        "conditionExpression": {
          "type": "group", "op": "AND",
          "children": [
            { "type": "comparison", "op": "isEmpty", "left": { "kind": "variable", "stepId": "collect-host", "field": "param", "paramName": "emptyField" } },
            { "type": "comparison", "op": "isFalse", "left": { "kind": "variable", "stepId": "trigger-manual", "field": "param", "paramName": "dryRun" } }
          ]
        }
      }
    },
    { "id": "e-jall1-notpanic", "source": "junction-all-1", "target": "log-not-panic",
      "type": "labeled",
      "data": {
        "label": "NOT contains PANIC",
        "conditionExpression": {
          "type": "not",
          "child": {
            "type": "comparison", "op": "contains",
            "left": { "kind": "variable", "stepId": "collect-host", "field": "output" },
            "right": { "kind": "literal", "value": "PANIC" }
          }
        }
      }
    },

