    {
      "type": "stat",
      "id": 10,
      "title": "RPS",
      "description": "Requests per second across all routes.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "nodepilot-prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{http_route=~\"$http_route\",http_route!~\"^/(metrics|healthz)(/.*)?$\"}[1m])) or vector(0)",
          "refId": "A",
          "legendFormat": "rps"
