    {
      "type": "table",
      "id": 30,
      "title": "Route Scorecard",
      "description": "Per-route RPS, p95 and 5xx-rate over the dashboard time range. Sortable.",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "prometheus",
        "uid": "nodepilot-prometheus"
      },
      "targets": [
        {
          "expr": "sum by (http_route, http_request_method) (rate(http_server_request_duration_seconds_count{http_route=~\"$http_route\"}[$__range]))",
          "legendFormat": "rps",
          "refId": "A",
          "format": "table",
          "instant": true
        },
        {
          "expr": "histogram_quantile(0.50, sum by (http_route, http_request_method, le) (rate(http_server_request_duration_seconds_bucket{http_route=~\"$http_route\"}[$__range])))",
          "legendFormat": "p50",
          "refId": "B",
          "format": "table",
          "instant": true
        },
        {
          "expr": "histogram_quantile(0.95, sum by (http_route, http_request_method, le) (rate(http_server_request_duration_seconds_bucket{http_route=~\"$http_route\"}[$__range])))",
          "legendFormat": "p95",
          "refId": "C",
          "format": "table",
          "instant": true
        },
        {
          "expr": "sum by (http_route, http_request_method) (rate(http_server_request_duration_seconds_count{http_response_status_code=~\"5..\",http_route=~\"$http_route\"}[$__range])) / clamp_min(sum by (http_route, http_request_method) (rate(http_server_request_duration_seconds_count{http_route=~\"$http_route\"}[$__range])), 0.0001)",
          "legendFormat": "err5xx",
          "refId": "D",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "indexByName": {
              "http_request_method": 0,
              "http_route": 1,
              "Value #A": 2,
              "Value #B": 3,
              "Value #C": 4,
              "Value #D": 5
            },
            "renameByName": {
              "http_request_method": "Method",
              "http_route": "Route",
              "Value #A": "RPS",
              "Value #B": "p50",
              "Value #C": "p95",
              "Value #D": "5xx Rate"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": true,
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Method"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 70
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Route"
            },
            "properties": [
