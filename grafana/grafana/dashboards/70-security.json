    {
      "type": "stat",
      "id": 10,
      "title": "Login Failure Rate (5m)",
      "description": "Share of login attempts that did not succeed.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "nodepilot-prometheus"
      },
      "targets": [
        {
          "expr": "(sum(rate(nodepilot_auth_login_attempts_total{result=\"failure\"}[5m])) or vector(0)) / clamp_min(sum(rate(nodepilot_auth_login_attempts_total[5m])), 0.0001)",
          "refId": "A",
          "legendFormat": "login failure rate 5m"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#10b981",
                "value": null
              },
              {
                "color": "#f59e0b",
                "value": 0.2
              },
              {
                "color": "#ef4444",
                "value": 0.5
              }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "colorMode": "background_solid",
        "graphMode": "none",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
