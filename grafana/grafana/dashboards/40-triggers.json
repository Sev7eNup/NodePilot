    {
      "type": "stat",
      "id": 10,
      "title": "Fires/min",
      "description": "Trigger fires per minute (5m rate).",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "nodepilot-prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(nodepilot_triggers_fired_total[5m])) * 60 or vector(0)",
          "refId": "A",
          "legendFormat": "fires min"
