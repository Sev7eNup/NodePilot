    {
      "type": "row",
      "id": 400,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 },
      "title": "Per-Workflow Scorecard (last 1h)",
      "collapsed": false,
      "panels": []
    },

    {
      "type": "table",
      "id": 40,
      "title": "Workflow Scorecard",
      "description": "Per-workflow KPIs over the dashboard time range. Click a row to deep-link to the per-workflow drilldown.",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "nodepilot-prometheus" },
      "targets": [
        { "expr": "sum by (workflow_name) (increase(nodepilot_executions_started_total[$__range]))", "legendFormat": "Started", "refId": "A", "format": "table", "instant": true },
        { "expr": "sum by (workflow_name) (increase(nodepilot_executions_completed_total{status=\"Succeeded\"}[$__range]))", "legendFormat": "Succeeded", "refId": "B", "format": "table", "instant": true },
        { "expr": "sum by (workflow_name) (increase(nodepilot_executions_completed_total{status=\"Failed\"}[$__range]))", "legendFormat": "Failed", "refId": "C", "format": "table", "instant": true },
        { "expr": "sum by (workflow_name) (increase(nodepilot_executions_completed_total{status=\"Cancelled\"}[$__range]))", "legendFormat": "Cancelled", "refId": "D", "format": "table", "instant": true },
        { "expr": "(sum by (workflow_name) (increase(nodepilot_executions_completed_total{status=\"Succeeded\"}[$__range])) or on(workflow_name) sum by (workflow_name) (0 * nodepilot_executions_started_total)) / clamp_min(sum by (workflow_name) (increase(nodepilot_executions_completed_total[$__range])), 0.0001)", "legendFormat": "SuccessRate", "refId": "E", "format": "table", "instant": true },
        { "expr": "histogram_quantile(0.50, sum by (workflow_name, le) (rate(nodepilot_execution_duration_milliseconds_bucket[$__range])))", "legendFormat": "p50", "refId": "F", "format": "table", "instant": true },
        { "expr": "histogram_quantile(0.95, sum by (workflow_name, le) (rate(nodepilot_execution_duration_milliseconds_bucket[$__range])))", "legendFormat": "p95", "refId": "G", "format": "table", "instant": true }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true },
            "indexByName": { "workflow_name": 0, "Value #A": 1, "Value #B": 2, "Value #C": 3, "Value #D": 4, "Value #E": 5, "Value #F": 6, "Value #G": 7 },
            "renameByName": {
              "workflow_name": "Workflow",
              "Value #A": "Started",
              "Value #B": "Succeeded",
              "Value #C": "Failed",
              "Value #D": "Cancelled",
              "Value #E": "Success Rate",
              "Value #F": "p50",
              "Value #G": "p95"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "filterable": true,
            "inspect": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Started" }, "properties": [
            { "id": "custom.cellOptions", "value": { "type": "color-text" } },
            { "id": "color", "value": { "mode": "fixed", "fixedColor": "#60a5fa" } },
            { "id": "decimals", "value": 0 }
          ]},
          { "matcher": { "id": "byName", "options": "Succeeded" }, "properties": [
            { "id": "custom.cellOptions", "value": { "type": "color-text" } },
            { "id": "color", "value": { "mode": "fixed", "fixedColor": "#10b981" } },
            { "id": "decimals", "value": 0 }
          ]},
          { "matcher": { "id": "byName", "options": "Failed" }, "properties": [
            { "id": "custom.cellOptions", "value": { "type": "color-text" } },
            { "id": "color", "value": { "mode": "fixed", "fixedColor": "#ef4444" } },
            { "id": "decimals", "value": 0 }
          ]},
          { "matcher": { "id": "byName", "options": "Cancelled" }, "properties": [
            { "id": "custom.cellOptions", "value": { "type": "color-text" } },
            { "id": "color", "value": { "mode": "fixed", "fixedColor": "#f59e0b" } },
            { "id": "decimals", "value": 0 }
          ]},
          { "matcher": { "id": "byName", "options": "Success Rate" }, "properties": [
            { "id": "unit", "value": "percentunit" },
            { "id": "decimals", "value": 2 },
            { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
            { "id": "thresholds", "value": { "mode": "absolute", "steps": [
              { "color": "#7f1d1d", "value": null },
              { "color": "#92400e", "value": 0.80 },
              { "color": "#065f46", "value": 0.95 }
            ]}},
            { "id": "min", "value": 0 },
            { "id": "max", "value": 1 }
          ]},
          { "matcher": { "id": "byName", "options": "p50" }, "properties": [
            { "id": "unit", "value": "ms" },
            { "id": "decimals", "value": 0 },
            { "id": "custom.cellOptions", "value": { "type": "color-text" } },
            { "id": "thresholds", "value": { "mode": "absolute", "steps": [
              { "color": "#10b981", "value": null },
              { "color": "#f59e0b", "value": 5000 },
              { "color": "#ef4444", "value": 30000 }
            ]}}
          ]},
          { "matcher": { "id": "byName", "options": "p95" }, "properties": [
            { "id": "unit", "value": "ms" },
            { "id": "decimals", "value": 0 },
            { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } },
            { "id": "thresholds", "value": { "mode": "absolute", "steps": [
              { "color": "#064e3b", "value": null },
              { "color": "#7c2d12", "value": 30000 },
              { "color": "#7f1d1d", "value": 120000 }
            ]}}
          ]},
          { "matcher": { "id": "byName", "options": "Workflow" }, "properties": [
            { "id": "custom.width", "value": 320 },
            { "id": "links", "value": [
              { "title": "Drill into ${__value.text}", "url": "/d/nodepilot-workflows-v2?var-workflow_name=${__value.text}&${__url_time_range}", "targetBlank": false }
            ]}
          ]}
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": true, "reducer": ["sum"], "fields": ["Started", "Succeeded", "Failed", "Cancelled"], "countRows": false, "enablePagination": false },
        "sortBy": [{ "displayName": "Failed", "desc": true }]
      }
    },

