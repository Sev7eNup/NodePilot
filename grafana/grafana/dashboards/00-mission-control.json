        "mode": "html",
        "code": { "language": "html", "showLineNumbers": false, "showMiniMap": false },
        "content": "<div style=\"display:flex;align-items:center;justify-content:space-between;padding:6px 18px;background:linear-gradient(135deg,#0f172a 0%,#1e293b 50%,#0f172a 100%);border-radius:6px;border:1px solid #334155;height:100%;\"><div><div style=\"font-size:24px;font-weight:700;color:#f1f5f9;letter-spacing:0.5px;\">NodePilot · Mission Control</div><div style=\"font-size:13px;color:#94a3b8;margin-top:4px;\">Workflow orchestration health · RED method (Rate · Errors · Duration) + system saturation</div></div><div style=\"display:flex;gap:14px;font-size:11px;\"><a href=\"/d/nodepilot-workflows-v2\" style=\"color:#60a5fa;text-decoration:none;padding:4px 10px;border:1px solid #1e40af;border-radius:4px;background:#1e3a8a30;\">Workflows</a><a href=\"/d/nodepilot-activities\" style=\"color:#60a5fa;text-decoration:none;padding:4px 10px;border:1px solid #1e40af;border-radius:4px;background:#1e3a8a30;\">Activities</a><a href=\"/d/nodepilot-winrm\" style=\"color:#60a5fa;text-decoration:none;padding:4px 10px;border:1px solid #1e40af;border-radius:4px;background:#1e3a8a30;\">WinRM</a><a href=\"/d/nodepilot-triggers\" style=\"color:#60a5fa;text-decoration:none;padding:4px 10px;border:1px solid #1e40af;border-radius:4px;background:#1e3a8a30;\">Triggers</a><a href=\"/d/nodepilot-api\" style=\"color:#60a5fa;text-decoration:none;padding:4px 10px;border:1px solid #1e40af;border-radius:4px;background:#1e3a8a30;\">API</a><a href=\"/d/nodepilot-runtime\" style=\"color:#60a5fa;text-decoration:none;padding:4px 10px;border:1px solid #1e40af;border-radius:4px;background:#1e3a8a30;\">Runtime</a><a href=\"/d/nodepilot-security\" style=\"color:#60a5fa;text-decoration:none;padding:4px 10px;border:1px solid #1e40af;border-radius:4px;background:#1e3a8a30;\">Security</a></div></div>"
      }
    },

    {
      "type": "row",
      "id": 100,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 },
      "title": "Live KPIs",
      "collapsed": false,
      "panels": []
    },

    {
      "type": "stat",
      "id": 10,
      "title": "Active Executions",
      "description": "Workflows currently running. Sustained spikes near the global cap (default 5000) hint at capacity pressure.",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "nodepilot-prometheus" },
      "targets": [
        { "expr": "sum(nodepilot_executions_active) or vector(0)", "legendFormat": "active", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 0,
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "#10b981", "value": null },
            { "color": "#3b82f6", "value": 1 },
            { "color": "#f59e0b", "value": 100 },
            { "color": "#ef4444", "value": 1000 }
          ]},
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "value_and_name",
        "wideLayout": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "percentChangeColorMode": "standard",
        "showPercentChange": false
      }
    },

    {
      "type": "stat",
      "id": 11,
      "title": "Throughput",
      "description": "Execution starts per minute over the last 5 min.",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "nodepilot-prometheus" },
      "targets": [
        { "expr": "sum(rate(nodepilot_executions_started_total[5m])) * 60 or vector(0)", "legendFormat": "exec/min", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "#475569", "value": null },
            { "color": "#3b82f6", "value": 0.01 }
          ]},
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "value_and_name",
        "wideLayout": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },

    {
      "type": "stat",
      "id": 12,
      "title": "Success Rate (1h)",
      "description": "Share of completed executions with status=Succeeded. <95% deserves a look; <80% is paging-worthy.",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "nodepilot-prometheus" },
      "targets": [
        {
          "expr": "(sum(rate(nodepilot_executions_completed_total{status=\"Succeeded\"}[1h])) or vector(0)) / clamp_min(sum(rate(nodepilot_executions_completed_total[1h])), 0.0001)",
          "legendFormat": "success",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 2,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "#ef4444", "value": null },
            { "color": "#f59e0b", "value": 0.80 },
            { "color": "#10b981", "value": 0.95 }
          ]},
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "colorMode": "background_solid",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "value_and_name",
        "wideLayout": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },

    {
      "type": "stat",
      "id": 13,
      "title": "p95 Duration (5m)",
      "description": "95th-percentile end-to-end execution latency.",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "nodepilot-prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(nodepilot_execution_duration_milliseconds_bucket[5m])) by (le)) or vector(0)",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "#10b981", "value": null },
            { "color": "#f59e0b", "value": 30000 },
            { "color": "#ef4444", "value": 120000 }
          ]},
          "unit": "ms"
        }
      },
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "value_and_name",
        "wideLayout": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },

    {
      "type": "stat",
      "id": 14,
      "title": "Failed (1h)",
      "description": "Count of executions completed with status=Failed in the last hour.",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "nodepilot-prometheus" },
      "targets": [
        { "expr": "sum(increase(nodepilot_executions_completed_total{status=\"Failed\"}[1h])) or vector(0)", "legendFormat": "failed/h", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
