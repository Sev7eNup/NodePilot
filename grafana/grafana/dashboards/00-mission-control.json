      "targets": [
        { "expr": "topk(10, sum by (workflow_name) (increase(nodepilot_executions_started_total[1h])))", "legendFormat": "{{workflow_name}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-BlPu" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
