      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(nodepilot_execution_duration_milliseconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(nodepilot_execution_duration_milliseconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(nodepilot_execution_duration_milliseconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": {
