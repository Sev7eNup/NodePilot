      "targets": [
        {
          "expr": "(sum(increase(nodepilot_steps_executed_total{activity_type=~\"$activity_type\",status=\"Failed\"}[$__range])) or vector(0)) / clamp_min(sum(increase(nodepilot_steps_executed_total{activity_type=~\"$activity_type\"}[$__range])) or vector(0.0001), 0.0001)",
          "refId": "A",
          "legendFormat": "step failure rate"
