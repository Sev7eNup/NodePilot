    {
      "type": "timeseries",
      "id": 43,
      "title": "Debug Sessions & Resume Commands",
      "description": "Active step-debugger pauses (gauge, left axis) + the resume verbs operators clicked (rate, right axis). Two units sharing a panel — read each series against its own axis.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 56
      },
      "datasource": {
        "type": "prometheus",
        "uid": "nodepilot-prometheus"
      },
      "targets": [
        {
          "expr": "sum(nodepilot_debug_sessions_active) or vector(0)",
          "legendFormat": "active sessions",
          "refId": "A"
        },
        {
          "expr": "sum by (mode) (rate(nodepilot_debug_resume_commands_total[2m]))",
          "legendFormat": "resume:{{mode}}/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "active sessions"
            },
