    {
      "type": "stat",
      "id": 10,
      "title": "Steps Executed",
      "description": "Total step executions across selected activity types over the dashboard time range.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "nodepilot-prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(nodepilot_steps_executed_total{activity_type=~\"$activity_type\"}[$__range])) or vector(0)",
          "refId": "A",
          "legendFormat": "steps executed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#3b82f6",
                "value": null
              }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "type": "stat",
