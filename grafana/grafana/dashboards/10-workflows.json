    {
      "type": "stat",
      "id": 10,
      "title": "Started",
      "description": "Total executions started for the selected workflows over the dashboard time range.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "nodepilot-prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(nodepilot_executions_started_total{workflow_name=~\"$workflow_name\"}[$__range])) or vector(0)",
          "refId": "A",
          "legendFormat": "started"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#3b82f6",
                "value": null
              }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "type": "stat",
      "id": 11,
      "title": "Success Rate",
      "description": "Succeeded / total completed.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "nodepilot-prometheus"
      },
      "targets": [
        {
          "expr": "(sum(increase(nodepilot_executions_completed_total{workflow_name=~\"$workflow_name\",status=\"Succeeded\"}[$__range])) or vector(0)) / clamp_min(sum(increase(nodepilot_executions_completed_total{workflow_name=~\"$workflow_name\"}[$__range])), 0.0001)",
          "refId": "A",
          "legendFormat": "success rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#ef4444",
                "value": null
              },
              {
                "color": "#f59e0b",
                "value": 0.8
              },
              {
                "color": "#10b981",
                "value": 0.95
              }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "colorMode": "background_solid",
        "graphMode": "none",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": [
