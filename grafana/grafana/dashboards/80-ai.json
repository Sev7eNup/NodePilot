    {
      "type": "row",
      "id": 100,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "title": "LLM KPIs",
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "id": 10,
      "title": "Calls (range)",
      "description": "Total LLM calls over the dashboard time range.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "nodepilot-prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(nodepilot_llm_calls_total[$__range])) or vector(0)",
          "refId": "A",
          "legendFormat": "calls range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#475569",
                "value": null
              },
              {
                "color": "#a78bfa",
                "value": 1
              }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "type": "stat",
      "id": 11,
      "title": "Success Rate",
      "description": "Share of LLM calls with result=success in the range.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "nodepilot-prometheus"
      },
      "targets": [
        {
          "expr": "(sum(increase(nodepilot_llm_calls_total{result=\"success\"}[$__range])) or vector(0)) / clamp_min(sum(increase(nodepilot_llm_calls_total[$__range])), 0.0001)",
          "refId": "A",
          "legendFormat": "success rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#ef4444",
                "value": null
              },
              {
                "color": "#f59e0b",
                "value": 0.8
              },
              {
                "color": "#10b981",
                "value": 0.95
              }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "colorMode": "background_solid",
        "graphMode": "none",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
