    {
      "type": "stat",
      "id": 10,
      "title": "Session Success Rate (5m)",
      "description": "Share of WinRM session-open attempts that succeeded.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "nodepilot-prometheus"
      },
      "targets": [
        {
          "expr": "(sum(rate(nodepilot_winrm_sessions_opened_total{result=\"ok\"}[5m])) or vector(0)) / clamp_min(sum(rate(nodepilot_winrm_sessions_opened_total[5m])), 0.0001)",
          "refId": "A",
          "legendFormat": "session success rate 5m"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#ef4444",
                "value": null
              },
              {
                "color": "#f59e0b",
                "value": 0.85
              },
              {
                "color": "#10b981",
                "value": 0.97
              }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "colorMode": "background_solid",
        "graphMode": "none",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
