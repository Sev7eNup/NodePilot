    {
      "type": "timeseries",
      "id": 20,
      "title": "Sessions Opened/s by Result",
      "description": "Stacked: ok / fail / cancelled session-open attempts.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "nodepilot-prometheus"
      },
      "targets": [
        {
          "expr": "sum by (result) (rate(nodepilot_winrm_sessions_opened_total[2m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {
              "group": "A",
              "mode": "normal"
            }
          },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "ok"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#10b981",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "fail"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#ef4444",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "cancelled"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#f59e0b",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "calcs": [
            "sum",
            "last"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      }
