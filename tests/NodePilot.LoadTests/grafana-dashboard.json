{
  "title": "NodePilot Load Test",
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Workflow executions — active",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(nodepilot_executions_active) or vector(0)", "legendFormat": "active" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Workflow executions — started rate (per sec)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(rate(nodepilot_executions_started_total[30s]))", "legendFormat": "started/s" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Execution duration (p50/p95/p99, ms)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(nodepilot_execution_duration_bucket[1m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(nodepilot_execution_duration_bucket[1m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(nodepilot_execution_duration_bucket[1m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Step duration by activity_type (p95, ms)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, activity_type) (rate(nodepilot_step_duration_bucket[1m])))", "legendFormat": "{{activity_type}}" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "SignalR — connections + messages/sec",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(nodepilot_signalr_connections_active) or vector(0)", "legendFormat": "connections" },
        { "expr": "sum by (event_type) (rate(nodepilot_signalr_messages_sent_total[30s]))", "legendFormat": "msg/s {{event_type}}" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": ".NET ThreadPool queue length",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        { "expr": "process_runtime_dotnet_thread_pool_queue_length", "legendFormat": "queue" }
      ]
    }
  ]
}
