# Copy to .env and fill in secrets. Never commit the real .env — .gitignore already excludes it.

# SQL Server SA password (SQL Server 2022 requires >= 8 chars, upper+lower+digit/symbol).
MSSQL_SA_PASSWORD=ChangeMe!Strong1

# Grafana admin password. Default admin account is "admin".
GF_SECURITY_ADMIN_PASSWORD=ChangeMeGrafana!

# Leave disabled for production. Flip to "true" only for throw-away local kiosks.
GF_AUTH_ANONYMOUS_ENABLED=false
