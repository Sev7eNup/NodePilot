{
  "Database": {
    "Provider": "postgres",
    "AllowInsecureTls": false
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=NodePilot;Trusted_Connection=True;TrustServerCertificate=False;Encrypt=Strict;Application Name=NodePilot;Min Pool Size=40;Max Pool Size=800",
    "Postgres": "Host=localhost;Port=5432;Database=nodepilot;Username=nodepilot;SSL Mode=VerifyFull;Check Certificate Revocation=true;Maximum Pool Size=800;Minimum Pool Size=40;Connection Idle Lifetime=60"
  },
  "Jwt": {
    "Issuer": "NodePilot",
    "Audience": "NodePilot"
  },
  "Authentication": {
    "LocalLoginMode": "BreakGlassOnly",
    "SessionAbsoluteLifetimeHours": 8,
    "MaxAuthorizationStalenessMinutes": 15,
    "Ldap": {
      "Enabled": false,
      "Endpoints": [],
      "Port": 636,
      "UseSsl": true,
      "AllowedGroupSids": [],
      "DirectorySyncIntervalMinutes": 5,
      "DirectorySyncMaxConcurrency": 16
    },
    "Windows": {
      "Enabled": false,
      "AllowNtlmFallback": false,
      "NtlmDisabledByPolicy": false
    },
    "Oidc": {
      "Enabled": false,
      "Scopes": ["openid", "profile", "email"],
      "AllowedGroupIds": []
    },
    "Scim": {
      "Enabled": false,
      "BearerToken": null,
      "PreviousBearerToken": null,
      "Authority": null
    }
  },
  "DataProtection": {
    "KeyRingPath": "data-protection-keys",
    "CertificateThumbprint": null,
    "SharedKeyRing": false
  },
  "Security": {
    "StrictAllowedHosts": true
  },
  "Swagger": {
    "DisableInNonDevelopment": true
  },
  "Credentials": {
    "DpapiScope": "CurrentUser"
  },
  "ExternalTrigger": {
    "ApiKey": ""
  },
  "Webhook": {
    "RequireSecret": true
  },
  "Remote": {
    "Provider": "winrm",
    "RequireWinRmSsl": true,
    "WinRm": {
      "OperationTimeoutSeconds": 300,
      "OpenTimeoutSeconds": 30
    },
    "Pool": {
      "Enabled": true,
      "MaxConcurrentPerMachine": 5,
      "MaxIdlePerKey": 5,
      "IdleTtlSeconds": 120
    },
    "Noop": {
      "MinLatencyMs": 0,
      "MaxLatencyMs": 0,
      "SimulateFailures": false,
      "FailureRate": 0.0
    }
  },
  "FileSystemOperation": {
    "RejectTraversal": true
  },
  "SqlActivity": {
    "RequireConnectionRef": true
  },
  "Trigger": {
    "Database": {
      "RequireConnectionRef": true
    }
  },
  "StartProgram": {
    "DisallowShellExecute": true
  },
  "ExecutionDispatch": {
    "Capacity": 2048,
    "WorkerCount": 600
  },
  "Engine": {
    "Debug": {
      "MaxPauseMinutes": 10
    },
    "MaxConcurrentExecutions": {
      "Global": 5000,
      "PerUser": 2000
    },
    "MaxConcurrentSteps": 600,
    "IsolatedDrainGraceSeconds": 5,
    "Runspace": {
      "MinRunspaces": 256,
      "MaxRunspaces": 768
    }
  },
  "Threading": {
    "MinWorkerThreads": 768,
    "MinIoCompletionThreads": 768
  },
  "Smtp": {
    "Host": "localhost",
    "Port": 25,
    "From": "nodepilot@localhost"
  },
  "Llm": {
    "Enabled": false,
    "BaseUrl": "http://127.0.0.1:1234/v1",
    "ApiKey": "EMPTY",
    "Model": "gemma-4-e4b",
    "MaxTokens": 128000,
    "TimeoutSeconds": 720,
    "EnableToolCalling": false,
    "ToolCallMaxDepth": 4
  },
  "AiKnowledge": {
    "Enabled": false,
    "DocsEnabled": true,
    "OperationalEnabled": true,
    "SourceCodeEnabled": false,
    "DocsRootPath": "",
    "SourceCodeRootPath": "",
    "DocsMaxFileBytes": 262144,
    "DocsMaxResults": 20,
    "SourceCodeMaxFileBytes": 262144,
    "SourceCodeMaxResults": 20
  },
  "Logging": {
    "Format": "cmtrace",
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Connection": "Warning",
      "Microsoft.EntityFrameworkCore.Infrastructure": "Warning"
    },
    "StepDetail": {
      "Enabled": false,
      "MaxOutputChars": 10000
    },
    "File": {
      "RetainedFileCountLimit": 7,
      "FileSizeLimitBytes": 104857600
    },
    "Redaction": {
      "Enabled": true
    },
    "SupportLog": {
      "Enabled": true,
      "Path": "",
      "RetainedFileCountLimit": 90,
      "FileSizeLimitBytes": 10485760,
      "DbProjectionEnabled": true
    }
  },
  "Retention": {
    "Executions": {
      "Enabled": true,
      "MaxAgeDays": 30,
      "IntervalMinutes": 60,
      "BatchSize": 500,
      "ArchivePath": ""
    },
    "AuditLog": {
      "Enabled": true,
      "MaxAgeDays": 365,
      "IntervalMinutes": 720,
      "BatchSize": 1000,
      "ArchivePath": "",
      "VerifyIntervalMinutes": 1440,
      "VerifyMaxFilesPerPass": 500
    },
    "WorkflowVersions": {
      "Enabled": true,
      "MaxVersionsPerWorkflow": 50,
      "IntervalMinutes": 1440,
      "BatchSize": 500
    },
    "SupportEvents": {
      "Enabled": true,
      "MaxAgeDays": 90,
      "IntervalMinutes": 360
    }
  },
  "Alerting": {
    "LongRunningSeconds": 600
  },
  "Stats": {
    "RefreshIntervalMinutes": 5,
    "WindowDays": 7
  },
  "RestApi": {
    "BlockPrivateNetworks": true,
    "AllowedHosts": [],
    "Proxy": {
      "Enabled": false,
      "Address": "",
      "BypassList": [],
      "Username": null,
      "Password": null
    }
  },
  "OpenTelemetry": {
    "Enabled": false,
    "ServiceName": "nodepilot-api",
    "Environment": "dev",
    "RedactHostnames": true,
    "MetricExportIntervalSeconds": 30,
    "Otlp": {
      "Endpoint": "http://localhost:4317",
      "Protocol": "grpc",
      "Headers": "",
      "BrowserEndpoint": ""
    },
    "Sampling": {
      "Mode": "ParentBasedTraceIdRatio",
      "Ratio": 1.0
    },
    "Exporters": {
      "Traces": true,
      "Metrics": true,
      "Logs": true,
      "PrometheusScrape": true,
      "PrometheusScrapeAllowAnonymous": false
    },
    "TraceUi": {
      "UrlTemplate": "",
      "BackendName": "Tempo"
    },
    "Prometheus": {
      "QueryEndpoint": "",
      "Username": "",
      "Password": "",
      "BearerToken": "",
      "TimeoutSeconds": 10
    }
  },
  "AllowedHosts": "localhost;127.0.0.1"
}
